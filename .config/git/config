[user]
	name = Neal Milstein
	email = neal.milstein@gmail.com
[alias]
  h = help
  s = status
  co = checkout
  sw = switch
  ci = commit
  cl = clone
  b = branch
  fa = fetch --all
  pl = pull
  ps = push
  re = rebase
  d = diff
  a = add
  aa = add -A
  st = stash
  rs = reset HEAD
  l = log --color --graph --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(cyan)<%an>%Creset%C(yellow)%d%Creset' --abbrev-commit
  la = log --all --color --graph --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(cyan)<%an>%Creset%C(yellow)%d%Creset' --abbrev-commit
  lb = log --branches --color --graph --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(cyan)<%an>%Creset%C(yellow)%d%Creset' --abbrev-commit
  p = log --color --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(cyan)<%an>%Creset%C(yellow)%d%Creset' --abbrev-commit --patch
  rpo = remote prune origin
  wip = ci -m "chore: wip"
	set-upstream = !git branch --set-upstream-to=origin/$(git branch --show-current)
[push]
  default = current
[merge]
  tool = nvimdiff
  conflictStyle = zdiff3
[diff]
  tool = nvimdiff
  ;colorMoved = default
  mnemonicprefix = true
	algorithm = histogram
[difftool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[color]
	ui = true
[color "diff"]
  meta = magenta
[core]
  ;pager = less -SRi
  ;pager = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less -SRi
  pager = delta
[pager]
	branch = false
[interactive]
  diffFilter = delta --color-only
[add.interactive]
  useBuiltin = false
[delta]
  side-by-side = true
  line-numbers = true
  navigate = true
  syntax-theme = TwoDark
  features = calochortus-lyallii-modified
[delta "calochortus-lyallii-modified"]
    # author: https://github.com/manojkarthick
    commit-decoration-style = overline
    dark = true
    file-added-label = [+]
    file-copied-label = [C]
    file-decoration-style = none
    file-modified-label = [M]
    file-removed-label = [-]
    file-renamed-label = [R]
    file-style = "#13a9e8 bold"
    hunk-header-decoration-style = none
    hunk-header-file-style = "#999999"
    hunk-header-line-number-style = bold "#03a4ff"
    hunk-header-style = line-number syntax
    line-numbers = true
    line-numbers-left-style = black
    ;line-numbers-minus-style = "#B10036"
    ;line-numbers-plus-style = "#03a4ff"
    line-numbers-right-style = black
    line-numbers-zero-style = "#777777"
    minus-emph-style = syntax bold "#780000"
    minus-style = syntax "#400000"
    plus-emph-style = syntax bold "#007800"
    plus-style = syntax "#004000"
    whitespace-error-style = "#280050" reverse
    zero-style = syntax
[includeIf "gitdir:~/hivemind/payone/"]
    path = ~/hivemind/payone/.gitconfig
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[advice]
	skippedCherryPicks = false
